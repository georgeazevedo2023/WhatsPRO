  "knowledge_base_faqs_added": [
    {
      "type": "faq",
      "title": "O que é batente? / Diferença entre kit completo e folha de porta",
      "content_short": "Explica que batente é o quadro de madeira que envolve a porta (moldura). Kit completo = folha + batente; só folha = sem moldura."
    },
    {
      "type": "faq",
      "title": "Qual a diferença entre R10 e R11? / Cerâmica antiderrapante / Piso de área molhada",
      "content_short": "R10 antiderrapante padrão (varanda, sacada). R11 antiderrapante reforçado (piscina, área molhada). REGRA: cerâmica externa em área molhada DEVE ser antiderrapante por norma NBR 13818."
    },
    {
      "type": "faq",
      "title": "Diferença entre escada extensiva, articulada e plataforma",
      "content_short": "Extensiva = 2 partes que deslizam (alturas maiores). Articulada/multifuncional = 4 articulações (vira A, I, plataforma). Plataforma = doméstica baixa com plataforma no topo."
    },
    {
      "type": "faq",
      "title": "Furadeira 220v ou 12v? / Com fio ou bateria?",
      "content_short": "220v = com fio (potência alta, uso doméstico em tomada). 12v = bateria/sem fio (mobilidade, ideal pra trabalho em altura ou onde não tem tomada perto)."
    },
    {
      "type": "faq",
      "title": "Cano de água é diferente de esgoto? / PVC marrom / PVC branco",
      "content_short": "Sim. Cano de água (PVC marrom, soldável) é pressurizado, paredes mais grossas. Cano de esgoto (PVC branco) é por gravidade, paredes mais finas. Não pode trocar um pelo outro."
    },
    {
      "type": "faq",
      "title": "Churrasqueira pré-moldada ou alumínio? / Qual escolher?",
      "content_short": "Pré-moldada = alvenaria fixa, mais durável e tradicional, exige instalação. Alumínio = portátil, leve, ideal pra apartamento ou área externa pequena. Pré-moldada é mais consultiva (medir espaço); alumínio é venda direta."
    }
  ]
